DATABASE_URL="postgresql://user:password@localhost:5432/saiban_temp"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-secret"

# Optional Cloudflare Turnstile CAPTCHA for public volunteer registration.
# If TURNSTILE_SECRET_KEY is set, registration requires a valid captcha token.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Public field-worker signup is closed unless this is explicitly set to true.
FIELD_WORKER_REGISTRATION_ENABLED="false"

# New orphan applications are paused unless this is explicitly set to true.
# Existing drafts remain editable and submittable while this is false.
NEW_APPLICATIONS_ENABLED="false"

ADMIN_NAME="Admin User"
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-admin-password"
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_ACCOUNT_ID=""
CLOUDFLARE_R2_ENDPOINT="https://<account_id>.r2.cloudflarestorage.com"
CLOUDFLARE_R2_PUBLIC_URL="https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev"
