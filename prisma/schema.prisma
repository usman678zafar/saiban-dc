generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}


enum UserRole {
  admin
  field_worker
  viewer
}

enum ApplicationStatus {
  draft
  submitted
  needs_correction
  validated
  rejected
  migrated
}

enum MigrationStatus {
  pending
  validated
  migrated
  rejected
}

enum DocumentType {
  child_photo
  child_b_form
  father_cnic
  father_death_certificate
  mother_cnic
  mother_death_certificate
  guardian_cnic
  school_letter
  medical_report
  imam_verification
  principal_verification
  house_photo
  other
}

enum RelativeType {
  paternal_grandfather
  maternal_grandfather
  paternal_uncle
  maternal_uncle
}

model User {
  id           String              @id @default(uuid())
  name         String?
  email        String              @unique
  phoneNumber  String?             @unique
  cnic         String?             @unique
  fieldWorkerId String?            @unique
  address      String?
  project      String?
  passwordHash String
  role         UserRole            @default(field_worker)
  applications OrphanApplication[] @relation("CreatedApplications")
  updatedApps  OrphanApplication[] @relation("UpdatedApplications")
  auditLogs    AuditLog[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
}

model OrphanApplication {
  id                         String             @id @default(uuid())
  registrationNumber         String?            @unique
  collectorId                String?
  collectorName              String?
  collectorProject           String?
  collectorCnic              String?
  collectorAddress           String?
  collectorContact           String?
  fatherName                 String?
  fatherDob                  DateTime?
  fatherAge                  Int?
  fatherCnic                 String?
  fatherEducation            String?
  fatherTongue               String?
  fatherNativeArea           String?
  fatherOccupation           String?
  fatherDateOfDeath          DateTime?
  fatherCauseOfDeath         String?
  motherName                 String?
  motherDob                  DateTime?
  motherAge                  Int?
  motherCnic                 String?
  motherEducation            String?
  motherTongue               String?
  motherNativeArea           String?
  motherAlive                String?
  motherSeparationReason     String?
  motherEmploymentStatus     String?
  motherIsGuardian           String?
  motherContact              String?
  motherIsHousewife          Boolean?
  motherOccupation           String?
  motherMonthlyIncome        Float?
  motherRemarried            Boolean?
  motherDeathDate            DateTime?
  motherDeathCause           String?
  guardianName               String?
  guardianRelationship       String?
  guardianGender             String?
  guardianCnic               String?
  guardianEducation          String?
  guardianMotherTongue       String?
  guardianNativeArea         String?
  guardianContact            String?
  guardianZakatStatus        String?
  guardianOccupation         String?
  guardianFamilyHolder       String?
  guardianFamilyHolderAmount Float?
  guardianFamilyMembersCount Int?
  guardianMonthlyIncome      Float?
  paternalGrandfatherName    String?
  paternalGrandfatherAge     Int?
  paternalGrandfatherOccupation String?
  paternalGrandfatherIncome  Float?
  maternalGrandfatherName    String?
  maternalGrandfatherAge     Int?
  maternalGrandfatherOccupation String?
  maternalGrandfatherIncome  Float?
  province                   String?
  city                       String?
  district                   String?
  tehsil                     String?
  residentialArea            String?
  fullAddress                String?
  longitude                  Float?
  latitude                   Float?
  gpsAccuracyMeters          Float?
  gpsCapturedAt              DateTime?
  houseOwnershipStatus       String?
  monthlyRent                Float?
  rentPaidBy                 String?
  houseOwner                 String?
  houseCondition             String?
  houseConditionRemarks      String?
  furnishingCondition        String?
  furnishingConditionRemarks String?
  childName                  String?
  gender                     String?
  caste                      String?
  sect                       String?
  bFormNumber                String?
  dateOfBirth                DateTime?
  age                        Int?
  totalBrothers              Int?
  totalSisters               Int?
  registeredBrothers         Int?
  registeredSisters          Int?
  siblingsUnder12            Int?
  childLivesWithMother       Boolean?
  livingSituationNotes       String?
  healthStatus               String?
  disabilityDetails           String?
  treatmentPlace             String?
  monthlyMedicalExpenses     Float?
  currentlyStudying          Boolean?
  notStudyingReason          String?
  educationStartCondition    String?
  currentClass               String?
  schoolName                 String?
  schoolAddress              String?
  enrolledInMadrasa          Boolean?
  madrasaName                String?
  madrasaEducationDetails    String?
  educationFeeStatus         String?
  monthlySchoolFee           Float?
  careerGoal                 String?
  technicalInterest          String?
  learningSkill              String?
  childMonthlyIncome         Float?
  householdEarnersCount      Int?
  totalHouseholdIncome       Float?
  receivingOtherAid          Boolean?
  otherAidSource             String?
  monthlyAidAmount           Float?
  notAppliedElsewhereReason  String?
  principalName              String?
  institutionName            String?
  verifiedStudentName        String?
  verifiedFatherName         String?
  verifiedClass              String?
  verifiedMonthlyFee         Float?
  principalSignatureFileKey  String?
  institutionStampFileKey    String?
  imamName                   String?
  mosqueName                 String?
  neighborhoodCity           String?
  imamMobile                 String?
  motherZakatStatus          String?
  imamSignatureFileKey       String?
  mosqueStampFileKey         String?
  guardianSignatureFileKey   String?
  termsAccepted              Boolean?           @default(false)
  termsAcceptedAt            DateTime?
  status                     ApplicationStatus  @default(draft)
  migrationStatus            MigrationStatus   @default(pending)
  mainSaibanId               String?
  migrationErrors            String?
  createdBy                  User               @relation("CreatedApplications", fields: [createdById], references: [id])
  createdById                String
  updatedBy                  User?              @relation("UpdatedApplications", fields: [updatedById], references: [id])
  updatedById                String?
  siblings                   Sibling[]
  relatives                  Relative[]
  householdAssets            HouseholdAsset[]
  documents                  ApplicationDocument[]
  auditLogs                  AuditLog[]
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
}

model Sibling {
  id                   String             @id @default(uuid())
  application          OrphanApplication  @relation(fields: [applicationId], references: [id])
  applicationId        String
  name                 String?
  age                  Int?
  occupation           String?
  monthlyIncomeOrFee   Float?
}

model Relative {
  id            String            @id @default(uuid())
  application   OrphanApplication @relation(fields: [applicationId], references: [id])
  applicationId String
  relativeType  RelativeType
  name          String?
  age           Int?
  occupation    String?
  monthlyIncome Float?
}

model HouseholdAsset {
  id            String            @id @default(uuid())
  application   OrphanApplication @relation(fields: [applicationId], references: [id])
  applicationId String
  assetType     String
  quantity      Float?
  value         Float?
}

model ApplicationDocument {
  id            String            @id @default(uuid())
  application   OrphanApplication @relation(fields: [applicationId], references: [id])
  applicationId String
  fileKey       String
  fileUrl       String?
  mimeType      String
  size          Int
  documentType  DocumentType
  createdAt     DateTime          @default(now())
}

model AuditLog {
  id          String   @id @default(uuid())
  tableName   String
  recordId    String
  action      String
  actor       User     @relation(fields: [actorId], references: [id])
  actorId     String
  application OrphanApplication @relation(fields: [applicationId], references: [id])
  applicationId String
  details     Json?
  createdAt   DateTime @default(now())
}
